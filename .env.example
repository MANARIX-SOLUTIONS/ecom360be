# ──────────────────────────────────────────────────────────────
# 360 PME Commerce — Environment Variables
# Copy to .env and fill in production values
# ──────────────────────────────────────────────────────────────

# ── Profile ──
SPRING_PROFILES_ACTIVE=dev          # dev | test | prod

# ── Database ──
# Option A (recommandé pour systemd): URL complète — évite UnknownHostException: ${DB_HOST}
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ecom360
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Option B: Neon / full URL (overrides above)
# SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&channelBinding=require

# ── Connection Pool (prod) ──
HIKARI_MIN_IDLE=10
HIKARI_MAX_POOL=40
HIKARI_CONNECTION_TIMEOUT=15000
HIKARI_IDLE_TIMEOUT=180000
HIKARI_MAX_LIFETIME=900000

# ── JWT (CHANGE IN PRODUCTION — min 32 chars) ──
JWT_SECRET=e737848516d708a1ed8ff4190644422e4681a4937b39f3dd59d8558b410708de
JWT_EXPIRATION_MS=3600000           # 1h
JWT_REFRESH_EXPIRATION_MS=86400000  # 24h

# ── Server ──
SERVER_PORT=8080
MANAGEMENT_PORT=8081                # actuator on separate port (prod)

# ── Tomcat (prod) ──
TOMCAT_MIN_THREADS=20
TOMCAT_MAX_THREADS=400
TOMCAT_ACCEPT_COUNT=200
TOMCAT_MAX_CONNECTIONS=16384

# ── Async ──
ASYNC_CORE_SIZE=4
ASYNC_MAX_SIZE=16
ASYNC_QUEUE_CAPACITY=200

# ── CORS ──
# Dev: * (default) or http://localhost:5173,http://localhost:5174
# Prod: https://espace.ecom360pme.com
# CORS_ALLOWED_ORIGINS=*

# ── App (frontend URL for email links) ──
# Prod: https://espace.ecom360pme.com
APP_URL=http://localhost:5173

# ── Mail (optional — when not set, emails are logged only) ──
# Docker with Maildev: MAIL_HOST=maildev MAIL_PORT=1025 (no auth)
# VPS/prod: leave MAIL_HOST empty (or set real SMTP) — "maildev" won't resolve
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@ecom360.local

# ── Features ──
SWAGGER_ENABLED=false               # false in prod
ACTUATOR_ENDPOINTS=health,info,metrics,prometheus,caches
ACTUATOR_HEALTH_DETAILS=when_authorized
HIBERNATE_STATS=false
